{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "freeminiworkshop\\.com" }],
      "destination": "https://microtrainingmethod.com",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www\\.freeminiworkshop\\.com" }],
      "destination": "https://microtrainingmethod.com",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "([^.]+)\\.freeminiworkshop\\.com" }],
      "destination": "/api/funnels/render"
    }
  ]
}
